## Decision Time calculation
.param VDIFF=50m
.model nmos nmos level=1 VTO=0.5 KP=200u
.model pmos pmos level=1 VTO=-0.5 KP=100u
.tran 0.1n 200n

.control
run

plot v(clk)
plot v(x)

* Align same switching cycle
meas tran t_clk when v(clk)=0.9 rise=2
meas tran t_out when v(x)=1.2 rise=2

let t_decision = t_out - t_clk

print t_clk t_out t_decision

.endc
